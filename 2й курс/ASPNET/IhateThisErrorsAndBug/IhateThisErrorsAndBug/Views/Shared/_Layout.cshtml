<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IhateThisErrorsAndBug</title>
    <link rel="stylesheet" href="~/css/site.css"/>

  </head>
<body>
    <header>
        <nav>
            
                
             
                    <ul class="navbar-nav flex-grow-1">
                        <li>
                            <a class="navbar-brand" asp-area="" asp-controller="Main" asp-action="main">IhateThisErrorsAndBug</a>
                        </li>
                        <li>
                    <a class="nav-link text-dark" asp-area="" asp-controller="Main" asp-action="cart">Корзина</a>
                        </li>
                        <li">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>

        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - IhateThisErrorsAndBug - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
